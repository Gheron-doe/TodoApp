<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             x:Class="TodoApp.Pages.TaskDetailPage"
             x:DataType="vm:TaskDetailViewModel"
             Title="{Binding PageTitle}">

    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="12">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12">

                <Label Text="TITEL" FontSize="11" TextColor="DarkGreen"/>
                <Entry Text="{Binding Title, Mode=TwoWay}" Placeholder="Geef een titel..."/>

                <Label Text="BESCHRIJVING" FontSize="11" TextColor="DarkGreen"/>
                <Editor Text="{Binding Description, Mode=TwoWay}"
                        AutoSize="TextChanges"
                        HeightRequest="100"/>

                <Label Text="VOOR WIE" FontSize="11" TextColor="DarkGreen"/>
                <Picker ItemsSource="{Binding Persons}"
                        SelectedItem="{Binding AssignedPerson, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding FirstName}"/>

                <Label Text="IS GEDAAN" FontSize="11" TextColor="DarkGreen"/>
                <CheckBox IsChecked="{Binding IsDone, Mode=TwoWay}" HorizontalOptions="Start"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="Annuleren"
                    BackgroundColor="Red"
                    TextColor="White"
                    Command="{Binding CancelCommand}"/>
            <Button Grid.Column="1"
                    Text="Bewaren"
                    BackgroundColor="Green"
                    TextColor="White"
                    Command="{Binding SaveCommand}"/>
        </Grid>
    </Grid>
</ContentPage>
